# Copy to .env for local development (never commit .env).
DATABASE_URL=postgres://duck:duck@localhost:5432/duck

# Where the app is reachable — QR generation and OIDC redirects.
BASE_URL=http://localhost:3000

# FF1 keys: 32 bytes hex, one per generation, append-only. Never remove one.
DUCK_KEY_GEN_0=4242424242424242424242424242424242424242424242424242424242424242
# Which generation new flocks mint under.
DUCK_KEY_CURRENT=0

# tower-sessions signing key (64 bytes hex).
SESSION_KEY=767674767674767674767674767674767674767674767674767674767674767674767674767674767674767674767674767674767674767674767674767476

# Object storage (MinIO locally; Tigris/S3 in prod).
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=duck-photos
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin

# OIDC providers. Locally only Keycloak is configured; the others are
# optional and activate when their variables are present.
OIDC_KEYCLOAK_ISSUER=http://localhost:8081/realms/ducks
OIDC_KEYCLOAK_CLIENT_ID=duck-web
OIDC_KEYCLOAK_SECRET=duck-web-secret
#OIDC_GOOGLE_CLIENT_ID=
#OIDC_GOOGLE_SECRET=
#OIDC_ENTRA_CLIENT_ID=
#OIDC_ENTRA_SECRET=
#OIDC_ENTRA_TENANT=
#OIDC_APPLE_CLIENT_ID=
#OIDC_APPLE_TEAM_ID=
#OIDC_APPLE_KEY_ID=
#OIDC_APPLE_PRIVATE_KEY=

# issuer|subject pairs granted is_admin on login, comma-separated.
ADMIN_IDENTITIES=
