# Copy to .env for local development (never commit .env).
# Full configuration reference: README.md → "Configuration".

# ── Required ────────────────────────────────────────────────────────────────

DATABASE_URL=postgres://duck:duck@localhost:5432/duck

# Public URL of this instance — QR label URLs and OIDC redirects derive from
# it. Cookies are marked Secure automatically when it starts with https://.
BASE_URL=http://localhost:3000

# FF1 code keys: 32 bytes of hex, one per generation, append-only. Generate
# with `openssl rand -hex 32`. NEVER reuse this dev value in production, and
# never remove or change a generation once labels have been printed.
DUCK_KEY_GEN_0=4242424242424242424242424242424242424242424242424242424242424242
# Which generation new flocks mint under.
DUCK_KEY_CURRENT=0

# ── Listener (optional) ─────────────────────────────────────────────────────
# Defaults to dual-stack IPv6+IPv4 on port 3000 ("[::]:3000").
#LISTEN_ADDR=[::]:3000
#PORT=3000

# ── Photo storage ───────────────────────────────────────────────────────────
# With STORAGE_ENDPOINT set: any S3-compatible store (MinIO, Tigris, AWS…).
# Without it: photos are kept in a local directory (STORAGE_LOCAL_PATH,
# default ./photos) — the zero-dependency option for small installs.
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=duck-photos
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
#STORAGE_LOCAL_PATH=./photos

# ── OIDC login providers ────────────────────────────────────────────────────
# At least one is needed to log in. Google / Microsoft Entra / Apple have
# dedicated variables (their issuers are fixed). ANY other spec-compliant
# provider (Keycloak, Authentik, Authelia, Zitadel, Okta, …) is added
# generically — pick a slug and set:
#   OIDC_<SLUG>_ISSUER / _CLIENT_ID / _SECRET  (+ optional _DISPLAY_NAME)
# The lowercased slug becomes the login path: /login/<slug>.

# Local dev Keycloak (from docker-compose.yml / scripts/dev-up.sh):
OIDC_KEYCLOAK_ISSUER=http://localhost:8081/realms/ducks
OIDC_KEYCLOAK_CLIENT_ID=duck-web
OIDC_KEYCLOAK_SECRET=duck-web-secret
#OIDC_KEYCLOAK_DISPLAY_NAME=Keycloak

#OIDC_GOOGLE_CLIENT_ID=
#OIDC_GOOGLE_SECRET=
#OIDC_ENTRA_CLIENT_ID=
#OIDC_ENTRA_SECRET=
#OIDC_ENTRA_TENANT=
#OIDC_APPLE_CLIENT_ID=
#OIDC_APPLE_TEAM_ID=
#OIDC_APPLE_KEY_ID=
#OIDC_APPLE_PRIVATE_KEY=

# ── Administration ──────────────────────────────────────────────────────────
# issuer|subject pairs granted is_admin on login, comma-separated.
ADMIN_IDENTITIES=

# ── Product knobs (optional; defaults shown) ────────────────────────────────
#CAP_FLOCKS_PER_USER=10
#CAP_MINT_BATCH_MAX=100
#CAP_UNORIGINATED_MAX=200
#MISSING_AFTER_DAYS=365
#FRONT_PAGE_LIMIT=20
